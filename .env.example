# OpenAI — required for embedding & LLM; leave blank for retrieval-only mode
OPENAI_API_KEY=

# Chroma
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=aiorctest

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# LLM
LLM_MODEL=gpt-4o-mini

# Splitter
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Database — SQLite by default; switch to PostgreSQL in production
DATABASE_URL=sqlite:///./aiorctest.db
# DATABASE_URL=postgresql://aiorctest:changeme@localhost:5432/aiorctest

# Auth / JWT
SECRET_KEY=change-me-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Promote these emails to superadmin on startup (comma-separated, case-insensitive)
# BOOTSTRAP_SUPERADMIN_EMAILS=you@example.com
